NODE_ENV=development
PORT=5047
MONGO_URI=mongodb://127.0.0.1:27017/status_dashboard
JWT_SECRET=change-this-to-a-long-random-secret
ADMIN_USERNAME=gavinash
ADMIN_PASSWORD=awienashlocalhost
# Set to true to overwrite ADMIN_USERNAME password from env at every server boot
ADMIN_SYNC_ON_BOOT=false

# Cache controls (milliseconds)
STATUS_CACHE_TTL_MS=15000
HEALTH_CACHE_TTL_MS=15000
SECURITY_CACHE_TTL_MS=60000
ANALYTICS_CACHE_TTL_MS=10000

# Analytics controls
REQUEST_ANALYTICS_WINDOW_MINUTES=60
EVENT_LOOP_SNAPSHOT_MS=10000
SLOW_REQUEST_THRESHOLD_MS=500
MAX_SLOW_REQUESTS=200
MAX_DURATION_SAMPLES_PER_WINDOW=2000
MAX_ENDPOINTS_PER_WINDOW=250
API_ONLY_METRICS=true

# PM2 logs controls
PM2_LOGS_DIR=/home/ubuntu/.pm2/logs
PM2_LOG_DEFAULT_LINES=200
PM2_LOG_MAX_LINES=2000
PM2_LOG_READ_CHUNK_BYTES=262144
PM2_LOG_MAX_READ_BYTES=1048576
PM2_LOGS_CACHE_TTL_MS=3000
PM2_APPS_CACHE_TTL_MS=15000
# Optional: restrict to specific app names
# PM2_LOG_ALLOWLIST=copy-checker,easeexit,elective,status-dashboard

# Alerts
ALERT_EMAIL_HOST=smtp.gmail.com
ALERT_EMAIL_PORT=587
ALERT_EMAIL_USER=your@email.com
ALERT_EMAIL_PASS=your-app-password
ALERT_EMAIL_FROM=alerts@yourdomain.com
ALERT_EMAIL_TO=you@yourdomain.com
ALERT_COOLDOWN_MINUTES=30

# Prometheus (optional - leave empty to disable auth)
PROMETHEUS_TOKEN=
