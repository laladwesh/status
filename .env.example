NODE_ENV=development
PORT=5047
MONGO_URI=mongodb://127.0.0.1:27017/status_dashboard
JWT_SECRET=change-this-to-a-long-random-secret
ADMIN_USERNAME=gavinash
ADMIN_PASSWORD=awienashlocalhost

# Cache controls (milliseconds)
STATUS_CACHE_TTL_MS=15000
HEALTH_CACHE_TTL_MS=15000
SECURITY_CACHE_TTL_MS=60000
ANALYTICS_CACHE_TTL_MS=10000

# Analytics controls
REQUEST_ANALYTICS_WINDOW_MINUTES=60
EVENT_LOOP_SNAPSHOT_MS=10000
SLOW_REQUEST_THRESHOLD_MS=500
MAX_SLOW_REQUESTS=200
MAX_DURATION_SAMPLES_PER_WINDOW=2000
MAX_ENDPOINTS_PER_WINDOW=250
API_ONLY_METRICS=true
